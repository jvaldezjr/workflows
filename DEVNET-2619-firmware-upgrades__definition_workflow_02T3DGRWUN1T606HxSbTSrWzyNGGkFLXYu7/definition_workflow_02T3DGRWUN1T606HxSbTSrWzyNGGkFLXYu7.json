      {
        "unique_name": "definition_activity_02T3DGSC11V6T60fwYuIMbjVhZR5XvSfd3d",
        "name": "LLM Prompt",
        "title": "Transform availableUpgrades",
        "type": "activity.openai_structured_output_agent",
        "base_type": "activity",
        "properties": {
          "action_timeout": 180,
          "chat_messages": [
            {
              "content": "Role: You are a JSON Data Transformation Assistant.\n\n\nTask: Parse the provided response.json file and transform the data for: appliance, switch, wireless, and switchCatalyst.\n\n\nStep 1: Version Comparison Logic:\nFor each product type, compare the currentVersion.shortName against every item in the availableVersions list.\n\n\nExclude ID: Remove the version if its id matches currentVersion.id.\nCatalyst Rule: For switchCatalyst, if the current version is \"IOS XE\", ignore any version starting with \"CS\".\nNumeric Segment Rule:\nSplit versions into integer lists (e.g., 18.1.5.1 -\u003e [18, 1, 5, 1]).\nCompare segments left-to-right. The first difference determines the higher version.\nIf all segments match but one is longer, the longer one is the upgrade.\nKeep only versions strictly greater than the current version.\n\nStep 2: Strict Output Schema:\nThe final output must be a single JSON object. For each product key (appliance, switch, wireless, switchCatalyst):\n\n\nThe ONLY key allowed inside the product object is availableUpgrades.\nDO NOT include currentVersion, lastUpgrade, nextUpgrade, or any other metadata.\nInside availableUpgrades, keep only these three attributes: id, shortName, and releaseType.\nIf no upgrades exist, return {\"availableUpgrades\": []}. If a product is missing, return null.\n\nOutput Constraints:\n\n\nOutput the raw JSON string only.\nDo not use markdown code blocks (no triple backticks).\nDo not include any introductory or explanatory text.\n\n\nJSON: $activity.definition_activity_02T3DGS977OV81yTTDXkbxgjOvgZmCn3IYh.output.variable_workflow_02LV1H3CNMB7K2eIEUcLniuSFXAmkGIOQJ2$",
              "role": "user"
            }
          ],
          "continue_on_failure": false,
          "description": "This Activity facilitates comprehensive interaction with Large Language Models (LLMs), allowing users to craft detailed prompts, manage conversational context through chat messages, and precisely define the structure of the expected output. It is designed to enable the generation and extraction of structured data from LLMs, supporting integration with various LLM providers like OpenAI and Azure AI.",
          "display_name": "Transform availableUpgrades",
          "modelName": "gpt-4.1",
          "runtime_user": {
            "target_default": true
          },
          "skip_execution": false,
          "systemPrompt": "Act as a JSON expert",
          "target": {
            "override_workflow_target": true,
            "target_id": "definition_target_02T2W6YKRAU4D6CoxTJ9wcDfVje94GKxwwZ"
          }
        },
        "object_type": "definition_activity"
      },
      {
        "unique_name": "definition_activity_02TFLXYEJOKSO60CO3iVE3GUYojDi7gbgpO",
        "name": "JSONPath Query",
        "title": "Extract switchCatalyst availableUpgrades",
        "type": "corejava.jsonpathquery",
        "base_type": "activity",
        "properties": {
          "action_timeout": 180,
          "continue_on_failure": false,
          "description": "JSONPath Query to get value in JSON",
          "display_name": "Extract switchCatalyst availableUpgrades",
          "input_json": "$activity.definition_activity_02T3DGSC11V6T60fwYuIMbjVhZR5XvSfd3d.output.content$",
          "jsonpath_queries": [
            {
              "jsonpath_query": "$.switchCatalyst.availableUpgrades[*].shortName",
              "jsonpath_query_name": "Version Short Name",
              "jsonpath_query_type": "string",
              "set_default_value": false,
              "zdate_type_format": "yyyy-MM-dd'T'HH:mm:ssZ"
            },
            {
              "jsonpath_query": "$.switchCatalyst.availableUpgrades[*].id",
              "jsonpath_query_name": "Version ID",
              "jsonpath_query_type": "string",
              "set_default_value": false,
              "zdate_type_format": "yyyy-MM-dd'T'HH:mm:ssZ"
            },
            {
              "jsonpath_query": "$.switchCatalyst.availableUpgrades[*].releaseType",
